rules_version = '2';

// ============================================================
//  Saltcard — Firestore Security Rules
//  วางกฎนี้ที่ Firebase Console → Firestore Database → Rules → Publish
//
//  ใช้คู่กับ Anonymous Auth (แอปล็อกอินให้เองเบื้องหลัง ไม่มีหน้า login)
//  ต้องเปิด: Console → Authentication → Sign-in method → Anonymous → Enable
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ต้องมี auth token ก่อนถึงอ่าน/เขียนได้
    // → บล็อกการยิง REST API ตรงจากสคริปต์/บอทที่ขโมย apiKey จากไฟล์ JS ไป
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
